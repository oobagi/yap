<Window x:Class="Yap.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YapOverlay"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Width="1400"
        Height="700"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Animation storyboards defined in code-behind for dynamic control -->
        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PillTransform"
                                            Storyboard.TargetProperty="X">
                <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="10"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="-8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="6"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="-4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Lava lamp gradient background (behind pill) -->
        <Canvas x:Name="GradientCanvas"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Width="400" Height="300"
                Margin="0,0,0,0"
                IsHitTestVisible="False">
            <Canvas.Effect>
                <BlurEffect Radius="80"/>
            </Canvas.Effect>
        </Canvas>

        <!-- Main pill container, centered at bottom -->
        <StackPanel x:Name="ContentStack"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,60">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" X="0" Y="100"/>
            </StackPanel.RenderTransform>

            <!-- Error message (shown above pill) -->
            <Border x:Name="ErrorBorder"
                    Visibility="Collapsed"
                    Background="#CC000000"
                    CornerRadius="14"
                    Padding="12,6"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="16" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ErrorIcon" Text="&#x26A0;&#xFE0F;" Foreground="#FF5555"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ErrorText" Foreground="White" FontSize="11"
                               FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Onboarding instruction text (shown above pill during onboarding) -->
            <Border x:Name="OnboardingBorder"
                    Visibility="Collapsed"
                    Background="#CC000000"
                    CornerRadius="14"
                    Padding="14,8"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="16" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <TextBlock x:Name="OnboardingText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>

            <!-- Elapsed timer (hands-free, shown above pill after 10s) -->
            <TextBlock x:Name="ElapsedTimer"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"
                       Foreground="#80FFFFFF"
                       FontSize="11"
                       FontWeight="Medium"
                       FontFamily="Consolas"/>

            <!-- The pill -->
            <Border x:Name="PillBorder"
                    HorizontalAlignment="Center"
                    CornerRadius="20"
                    MinWidth="60"
                    MinHeight="40"
                    Cursor="Hand"
                    MouseLeftButtonDown="Pill_MouseLeftButtonDown"
                    MouseEnter="Pill_MouseEnter"
                    MouseLeave="Pill_MouseLeave"
                    ToolTip="Click to record">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="PillScale" ScaleX="1" ScaleY="1" CenterX="30" CenterY="20"/>
                        <TranslateTransform x:Name="PillTransform" X="0" Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="#BF000000"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="16" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="PillStroke" Color="#4DFFFFFF"/>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>1</Thickness>
                </Border.BorderThickness>

                <Grid Margin="12,6">
                    <!-- Waveform bars (recording mode) -->
                    <StackPanel x:Name="WaveformPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <!-- 11 bars, created dynamically in code-behind -->
                    </StackPanel>

                    <!-- Processing indicator -->
                    <StackPanel x:Name="ProcessingPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <!-- 11 processing bars with shimmer, created dynamically -->
                    </StackPanel>

                    <!-- Hands-free controls -->
                    <StackPanel x:Name="HandsFreePanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">

                        <!-- Pause/Resume button -->
                        <Border x:Name="PauseButton"
                                Width="26" Height="26"
                                CornerRadius="13"
                                Background="#26FFFFFF"
                                Cursor="Hand"
                                MouseLeftButtonDown="PauseButton_Click"
                                Margin="0,0,8,0">
                            <TextBlock x:Name="PauseIcon"
                                       Text="&#x2016;"
                                       Foreground="#E6FFFFFF"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Waveform in between (mini version) -->
                        <StackPanel x:Name="HandsFreeWaveform"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                        </StackPanel>

                        <!-- Stop button -->
                        <Border x:Name="StopButton"
                                Width="26" Height="26"
                                CornerRadius="13"
                                Background="#D9FF0000"
                                Cursor="Hand"
                                MouseLeftButtonDown="StopButton_Click"
                                Margin="8,0,0,0">
                            <TextBlock Text="&#x25A0;"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Idle / hover mic icon -->
                    <TextBlock x:Name="MicIcon"
                               Text="&#x1F3A4;"
                               FontSize="13"
                               Foreground="#E6FFFFFF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
