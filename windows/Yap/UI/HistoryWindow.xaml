<Window x:Class="Yap.UI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcription History"
        Width="520" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="400" MinHeight="300"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="CopyButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F3F"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="ClearButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FF5555"/>
            <Setter Property="BorderBrush" Value="#3F3F3F"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- History list -->
        <ListBox x:Name="HistoryList" Grid.Row="0"
                 Background="#1E1E1E"
                 BorderThickness="0"
                 Padding="8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0AFFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10,8" CornerRadius="6" Margin="2,2"
                            Cursor="Hand"
                            MouseLeftButtonDown="EntryBorder_Click"
                            Tag="{Binding FullText}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="{Binding TruncatedText}"
                                           Foreground="#DDDDDD"
                                           FontSize="13"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding RelativeTime}"
                                               Foreground="#777777" FontSize="10"/>
                                    <TextBlock Text="  &#x2022;  " Foreground="#444444" FontSize="10"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ProviderLabel}"
                                               Foreground="#667788" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Copy"
                                    Style="{StaticResource CopyButton}"
                                    VerticalAlignment="Center"
                                    Click="CopyEntry_Click"
                                    Tag="{Binding FullText}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="&#x1F399;"
                       FontSize="32"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       Opacity="0.3"/>
            <TextBlock Text="No transcriptions yet"
                       Foreground="#666666"
                       FontSize="14"
                       FontWeight="Medium"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Your transcription history will appear here"
                       Foreground="#444444"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Bottom bar -->
        <Border Grid.Row="1" BorderBrush="#3F3F3F" BorderThickness="0,1,0,0"
                Background="#1E1E1E" Padding="16,10">
            <Grid>
                <TextBlock x:Name="EntryCountText"
                           Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <Button x:Name="ClearButton" Content="Clear History"
                        Style="{StaticResource ClearButton}"
                        HorizontalAlignment="Right"
                        Click="ClearHistory_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
