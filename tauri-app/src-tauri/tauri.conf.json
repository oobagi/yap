{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yap",
  "version": "2.1.2",
  "identifier": "com.yap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Yap",
        "url": "/settings.html",
        "width": 500,
        "height": 680,
        "visible": false,
        "center": true,
        "resizable": false
      },
      {
        "label": "history",
        "title": "Transcription History",
        "url": "/history.html",
        "width": 520,
        "height": 500,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["sounds/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
