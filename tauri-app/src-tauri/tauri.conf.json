{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yap",
  "version": "1.0.0",
  "identifier": "com.yap.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "url": "/overlay.html",
        "width": 1400,
        "height": 700,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Yap Settings",
        "url": "/settings.html",
        "width": 500,
        "height": 680,
        "visible": false,
        "center": true,
        "resizable": false
      },
      {
        "label": "history",
        "title": "Transcription History",
        "url": "/history.html",
        "width": 520,
        "height": 500,
        "visible": false,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Yap"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
